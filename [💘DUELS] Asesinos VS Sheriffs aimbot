-- === ESP ARREGLADO (universal - funciona siempre) ===
local function createESP(player)
    if player == LocalPlayer then return end
    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.new(1, 0, 0)
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = player.Character
    highlight.Parent = player.Character
    espHighlights[player] = highlight
end

local function updateESP()
    for player, hl in pairs(espHighlights) do
        if not player.Character or player.Character:FindFirstChild("HumanoidRootPart") == nil then
            hl:Destroy()
            espHighlights[player] = nil
        end
    end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and not espHighlights[player] then
            createESP(player)
        end
    end
end

-- === WEAPON & SHOOT (igual que antes, funciona) ===
local function updateWeapon()
    local char = LocalPlayer.Character
    if not char then return end
    local tool = nil
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") and (v:FindFirstChild("fire") or v:FindFirstChild("kill")) then
            tool = v
            break
        end
    end
    if tool ~= currentWeapon then
        currentWeapon = tool
    end
end

local function getClosestEnemy()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = char.HumanoidRootPart
    local closest, dist = nil, aimDistance
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
            if d < dist then
                closest = p
                dist = d
            end
        end
    end
    return closest
end

local function shoot(target)
    if tick() - lastShot < shotDelay then return end
    lastShot = tick()
    if not currentWeapon then return end
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local tchar = target.Character
    if not tchar then return end
    local thrp = tchar.HumanoidRootPart
    local dir = (thrp.Position - hrp.Position).Unit

    pcall(function()
        if currentWeapon:FindFirstChild("fire") then currentWeapon.fire:FireServer() end
        if currentWeapon:FindFirstChild("kill") then currentWeapon.kill:FireServer(target, dir, hrp.Position) end
    end)
end

-- === INVISIBLE & FLY (nuevo tab) ===
local invisibleEnabled = false
local function toggleInvisible(state)
    invisibleEnabled = state
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Transparency = state and 1 or 0
        end
    end
end

-- Fly Tool (ITEM DE VOLAR INVISIBLE)
local flyTool
local function giveFlyTool()
    if flyTool and flyTool.Parent then flyTool:Destroy() end
    flyTool = Instance.new("Tool")
    flyTool.Name = "👻 Invisible Fly Tool"
    flyTool.RequiresHandle = false
    flyTool.Parent = LocalPlayer.Backpack

    local flying = false
    local bg, bv, flyConn

    flyTool.Activated:Connect(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        flying = not flying
        toggleInvisible(flying) -- vuela + invisible al mismo tiempo

        if flying then
            bg = Instance.new("BodyGyro", char.HumanoidRootPart)
            bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            bg.P = 9e4
            bv = Instance.new("BodyVelocity", char.HumanoidRootPart)
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            flyConn = RunService.Heartbeat:Connect(function()
                local cam = Workspace.CurrentCamera
                local vel = Vector3.new()
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cam.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cam.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0,1,0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel = vel - Vector3.new(0,1,0) end
                bv.Velocity = vel.Unit * 70
            end)
        else
            if flyConn then flyConn:Disconnect() end
            if bg then bg:Destroy() end
            if bv then bv:Destroy() end
            toggleInvisible(false)
        end
    end)
end

